# imports: http://example.org/ontology/uco-gufo
# imports: https://ontology.caseontology.org/case/case/1.4.0

@prefix drafting: <http://example.org/ontology/drafting/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix uco-core: <https://ontology.unifiedcyberontology.org/uco/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/ontology/case-gufo>
	a owl:Ontology ;
	owl:imports
		<http://example.org/ontology/uco-gufo> ,
		<https://ontology.caseontology.org/case/case/1.4.0>
		;
	.

